# Supabase – انسخ هذا الملف إلى .env واملأ القيم من لوحة Supabase (Project Settings > API)
# Copy this file to .env and fill values from Supabase Dashboard (Project Settings > API)

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key

# اختياري – للمرجع فقط (الكود لا يستخدمه)
# VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF
